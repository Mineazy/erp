// ============ POS ============

model ErpPosSession {
  id             String   @id @default(uuid())
  sessionNumber  String   @unique @map("session_number")
  openedAt       DateTime @default(now()) @map("opened_at")
  closedAt       DateTime? @map("closed_at")
  status         String   @default("open")
  openedBy       String   @map("opened_by")
  closedBy       String?  @map("closed_by")
  openingBalance Decimal  @default(0) @db.Decimal(15, 2) @map("opening_balance")
  closingBalance Decimal? @db.Decimal(15, 2) @map("closing_balance")
  totalSales     Decimal  @default(0) @db.Decimal(15, 2) @map("total_sales")
  totalRefunds   Decimal  @default(0) @db.Decimal(15, 2) @map("total_refunds")
  cashSales      Decimal  @default(0) @db.Decimal(15, 2) @map("cash_sales")
  cardSales      Decimal  @default(0) @db.Decimal(15, 2) @map("card_sales")
  mobileSales    Decimal  @default(0) @db.Decimal(15, 2) @map("mobile_sales")
  creditSales    Decimal  @default(0) @db.Decimal(15, 2) @map("credit_sales")
  currency       String   @default("USD")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  transactions ErpPosTransaction[]

  @@map("erp_pos_sessions")
}

model ErpPosTransaction {
  id                String   @id @default(uuid())
  transactionNumber String   @unique @map("transaction_number")
  sessionId         String   @map("session_id")
  session           ErpPosSession @relation(fields: [sessionId], references: [id])
  customerId        String?  @map("customer_id")
  customerName      String?  @map("customer_name")
  subtotal          Decimal  @db.Decimal(15, 2)
  taxAmount         Decimal  @default(0) @db.Decimal(15, 2) @map("tax_amount")
  discount          Decimal  @default(0) @db.Decimal(15, 2)
  total             Decimal  @db.Decimal(15, 2)
  paidAmount        Decimal  @db.Decimal(15, 2) @map("paid_amount")
  changeAmount      Decimal  @default(0) @db.Decimal(15, 2) @map("change_amount")
  paymentMethod     String   @default("cash") @map("payment_method")
  status            String   @default("completed")
  currency          String   @default("USD")
  exchangeRate      Decimal  @default(1) @db.Decimal(15, 6) @map("exchange_rate")
  fiscalisedDocId   String?  @unique @map("fiscalised_doc_id")
  postedToJournal   Boolean  @default(false) @map("posted_to_journal")
  notes             String?
  isOffline         Boolean  @default(false) @map("is_offline")
  syncedAt          DateTime? @map("synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  lines        ErpPosTransactionLine[]
  payments     ErpPosPayment[]
  fiscalisedDoc FiscalisedDocument? @relation(fields: [fiscalisedDocId], references: [id])

  @@map("erp_pos_transactions")
}

model ErpPosTransactionLine {
  id            String  @id @default(uuid())
  transactionId String  @map("transaction_id")
  transaction   ErpPosTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String  @map("product_id")
  productName   String  @map("product_name")
  quantity      Decimal @db.Decimal(15, 2)
  unitPrice     Decimal @db.Decimal(15, 2) @map("unit_price")
  total         Decimal @db.Decimal(15, 2)
  batchNo       String? @map("batch_no")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("erp_pos_transaction_lines")
}

model ErpPosPayment {
  id            String  @id @default(uuid())
  transactionId String  @map("transaction_id")
  transaction   ErpPosTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  method        String
  amount        Decimal @db.Decimal(15, 2)
  reference     String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("erp_pos_payments")
}

// ============ RETURNS ============

model ErpReturn {
  id            String   @id @default(uuid())
  returnNumber  String   @unique @map("return_number")
  returnDate    DateTime @default(now()) @map("return_date")
  customerName  String?  @map("customer_name")
  referenceType String   @default("direct") @map("reference_type")
  referenceId   String?  @map("reference_id")
  reason        String?
