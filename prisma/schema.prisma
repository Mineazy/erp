  @@map("erp_return_lines")
}

// ============ HR ============

model ErpEmployee {
  id              String   @id @default(uuid())
  employeeNo      String   @unique @map("employee_no")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  email           String?
  phone           String?
  address         String?
  department      String?
  position        String?
  employmentType  String   @default("permanent") @map("employment_type")
  dateHired       DateTime @map("date_hired")
  tinNumber       String?  @map("tin_number")
  nssaNumber      String?  @map("nssa_number")
  necNumber       String?  @map("nec_number")
  zimdefNumber    String?  @map("zimdef_number")
  basicSalary     Decimal  @db.Decimal(15, 2) @map("basic_salary")
  currency        String   @default("USD")
  bankName        String?  @map("bank_name")
  bankAccount     String?  @map("bank_account")
  isActive        Boolean  @default(true) @map("is_active")
  userId          String?  @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")
