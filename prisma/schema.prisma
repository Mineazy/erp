}

model ErpCycleCount {
  id          String   @id @default(uuid())
  countNo     String   @unique @map("count_no")
  warehouseId String   @map("warehouse_id")
  warehouse   ErpWarehouse @relation(fields: [warehouseId], references: [id])
  status      String   @default("draft")
  countedBy   String   @map("counted_by")
  countedAt   DateTime @default(now()) @map("counted_at")
  approvedBy  String?  @map("approved_by")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lines ErpCycleCountLine[]

  @@map("erp_cycle_counts")
}

model ErpCycleCountLine {
  id          String  @id @default(uuid())
  countId     String  @map("count_id")
  count       ErpCycleCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  productName String  @map("product_name")
  expectedQty Decimal @db.Decimal(15, 2) @map("expected_qty")
  countedQty  Decimal @db.Decimal(15, 2) @map("counted_qty")
