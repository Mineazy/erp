generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ AUDIT TRAIL (Immutable) ============

model AuditLog {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  changes    Json
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ============ MULTI-CURRENCY ============

model CurrencyRate {
  id        String   @id @default(uuid())
  fromCurrency String @map("from_currency")
  toCurrency   String @map("to_currency")
  rate      Decimal  @db.Decimal(15, 6)
  date      DateTime @default(now())
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("currency_rates")
}

// ============ ZIMRA TAX ENGINE ============

model TaxType {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  category  String
  rate      Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true) @map("is_active")
  rules     Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions   TaxTransaction[]

  @@map("tax_types")
}

model TaxTransaction {
  id            String   @id @default(uuid())
  reference     String
  referenceType String   @map("reference_type")
  taxTypeId     String   @map("tax_type_id")
  taxType       TaxType  @relation(fields: [taxTypeId], references: [id])
  taxableAmount Decimal  @db.Decimal(15, 2) @map("taxable_amount")
  taxAmount     Decimal  @db.Decimal(15, 2) @map("tax_amount")
  rate          Decimal  @db.Decimal(5, 2)
  currency      String   @default("USD")
  exchangeRate  Decimal  @default(1) @db.Decimal(15, 6) @map("exchange_rate")
  postedToTaRMS Boolean  @default(false) @map("posted_to_tarms")
  createdAt     DateTime @default(now()) @map("created_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  @@map("tax_transactions")
}

model WithholdingTaxCertificate {
  id             String   @id @default(uuid())
  certificateNo  String   @unique @map("certificate_no")
  supplierId     String   @map("supplier_id")
  supplierName   String   @map("supplier_name")
  supplierTin    String?  @map("supplier_tin")
  invoiceRef     String   @map("invoice_ref")
  grossAmount    Decimal  @db.Decimal(15, 2) @map("gross_amount")
  whtAmount      Decimal  @db.Decimal(15, 2) @map("wht_amount")
  rate           Decimal  @db.Decimal(5, 2)
  itf263Verified Boolean  @default(false) @map("itf263_verified")
  period         String
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("withholding_tax_certificates")
}

// ============ FDMS FISCALISATION ============

model FdmsDevice {
  id              String   @id @default(uuid())
  deviceId        String   @unique @map("device_id")
  serialNo        String   @unique @map("serial_no")
  activationKey   String?  @map("activation_key")
  certificate     String?  @db.Text
  privateKey      String?  @db.Text @map("private_key")
  status          String   @default("registered")
  fiscalDayNo     Int      @default(0) @map("fiscal_day_no")
  receiptCounter  Int      @default(0) @map("receipt_counter")
  receiptGlobalNo Int      @default(0) @map("receipt_global_no")
  lastSyncAt      DateTime? @map("last_sync_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  fiscalisedDocuments FiscalisedDocument[]

  @@map("fdms_devices")
}

model FiscalisedDocument {
  id            String   @id @default(uuid())
  documentType  String   @map("document_type")
  documentRef   String   @map("document_ref")
  deviceId      String   @map("device_id")
  device        FdmsDevice @relation(fields: [deviceId], references: [id])
  fiscalDayNo   Int      @map("fiscal_day_no")
  receiptNo     Int      @map("receipt_no")
  receiptGlobalNo Int    @map("receipt_global_no")
  authCode      String?  @map("auth_code")
  qrCodeData    String?  @map("qr_code_data")
  qrCodeUrl     String?  @map("qr_code_url")
  submittedAt   DateTime? @map("submitted_at")
  status        String   @default("pending")
  errorMessage  String?  @map("error_message")
  retryCount    Int      @default(0) @map("retry_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  posTransaction ErpPosTransaction?

  @@map("fiscalised_documents")
}

// ============ CORE FINANCIAL ============

model ErpChartOfAccounts {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  type      String
  category  String?
  isHeader  Boolean  @default(false) @map("is_header")
  parentId  String?  @map("parent_id")
  parent    ErpChartOfAccounts?  @relation("ChartOfAccountsTree", fields: [parentId], references: [id])
  children  ErpChartOfAccounts[] @relation("ChartOfAccountsTree")
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  currency  String   @default("USD")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  journalLines  ErpJournalLine[]

  @@map("erp_chart_of_accounts")
}

model ErpJournalEntry {
  id          String   @id @default(uuid())
  entryNumber String   @unique @map("entry_number")
  description String
  entryDate   DateTime @map("entry_date")
  period      String
  status      String   @default("draft")
  postedAt    DateTime? @map("posted_at")
  postedBy    String?  @map("posted_by")
  currency    String   @default("USD")
  exchangeRate Decimal @default(1) @db.Decimal(15, 6) @map("exchange_rate")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  lines ErpJournalLine[]

  @@map("erp_journal_entries")
}

model ErpJournalLine {
  id          String   @id @default(uuid())
  entryId     String   @map("entry_id")
  accountId   String   @map("account_id")
  description String?
  debit       Decimal  @default(0) @db.Decimal(15, 2)
  credit      Decimal  @default(0) @db.Decimal(15, 2)
  currency    String   @default("USD")
  createdAt   DateTime @default(now()) @map("created_at")

  entry   ErpJournalEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account ErpChartOfAccounts   @relation(fields: [accountId], references: [id])

  @@map("erp_journal_lines")
}

model ErpAccountReceivable {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique @map("invoice_number")
  customerId    String   @map("customer_id")
  customerName  String   @map("customer_name")
  invoiceDate   DateTime @map("invoice_date")
  dueDate       DateTime @map("due_date")
  amount        Decimal  @db.Decimal(15, 2)
  paidAmount    Decimal  @default(0) @db.Decimal(15, 2) @map("paid_amount")
  balance       Decimal  @db.Decimal(15, 2)
  status        String   @default("pending")
  currency      String   @default("USD")
  description   String?
  journalEntryId String? @map("journal_entry_id")
  fiscalisedDocId String? @map("fiscalised_doc_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  @@map("erp_accounts_receivable")
}

model ErpAccountPayable {
  id            String   @id @default(uuid())
  billNumber    String   @unique @map("bill_number")
  supplierId    String   @map("supplier_id")
  supplierName  String   @map("supplier_name")
  billDate      DateTime @map("bill_date")
  dueDate       DateTime @map("due_date")
  amount        Decimal  @db.Decimal(15, 2)
  paidAmount    Decimal  @default(0) @db.Decimal(15, 2) @map("paid_amount")
  balance       Decimal  @db.Decimal(15, 2)
  status        String   @default("pending")
  currency      String   @default("USD")
  description   String?
  journalEntryId String? @map("journal_entry_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  @@map("erp_accounts_payable")
}

model ErpCashbook {
  id          String   @id @default(uuid())
  entryNumber String   @unique @map("entry_number")
  entryDate   DateTime @map("entry_date")
  type        String
  accountId   String   @map("account_id")
  description String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("USD")
  exchangeRate Decimal @default(1) @db.Decimal(15, 6) @map("exchange_rate")
  reference   String?
  status      String   @default("posted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  @@map("erp_cashbook")
}

// ============ INVENTORY & ORDERS ============

model ErpProduct {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  categoryId  String?  @map("category_id")
  category    ErpProductCategory? @relation(fields: [categoryId], references: [id])
  unit        String   @default("each")
  costPrice   Decimal  @default(0) @db.Decimal(15, 2) @map("cost_price")
  sellingPrice Decimal @default(0) @db.Decimal(15, 2) @map("selling_price")
  stock       Decimal  @default(0) @db.Decimal(15, 2)
  minStock    Decimal  @default(0) @db.Decimal(15, 2) @map("min_stock")
  maxStock    Decimal? @default(0) @db.Decimal(15, 2) @map("max_stock")
  location    String?
  barcode     String?
  costingMethod String @default("weighted_average") @map("costing_method")
  isActive    Boolean  @default(true) @map("is_active")
  grade       String?
  purity      Decimal? @db.Decimal(5, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  batches          ErpProductBatch[]
  warehouseStocks  ErpWarehouseStock[]

  @@map("erp_products")
}

model ErpProductCategory {
  id        String   @id @default(uuid())
  name      String
  parentId  String?  @map("parent_id")
  products  ErpProduct[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("erp_product_categories")
}

model ErpProductBatch {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  product     ErpProduct @relation(fields: [productId], references: [id])
  batchNo     String   @map("batch_no")
  serialNo    String?  @map("serial_no")
  quantity    Decimal  @db.Decimal(15, 2)
  costPrice   Decimal  @db.Decimal(15, 2) @map("cost_price")
  receivedAt  DateTime @default(now()) @map("received_at")
  expiryDate  DateTime? @map("expiry_date")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("erp_product_batches")
}

model ErpSalesOrder {
  id          String   @id @default(uuid())
  orderNumber String   @unique @map("order_number")
  customerId  String   @map("customer_id")
  customerName String  @map("customer_name")
  orderDate   DateTime @map("order_date")
  status      String   @default("draft")
  subtotal    Decimal  @db.Decimal(15, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(15, 2) @map("tax_amount")
  discount    Decimal  @default(0) @db.Decimal(15, 2)
  total       Decimal  @db.Decimal(15, 2)
  currency    String   @default("USD")
  exchangeRate Decimal @default(1) @db.Decimal(15, 6) @map("exchange_rate")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  lines ErpSalesOrderLine[]

  @@map("erp_sales_orders")
}

model ErpSalesOrderLine {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  productName String @map("product_name")
  quantity  Decimal @db.Decimal(15, 2)
  unitPrice Decimal @db.Decimal(15, 2) @map("unit_price")
  total     Decimal @db.Decimal(15, 2)

  order ErpSalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("erp_sales_order_lines")
}

model ErpPurchaseOrder {
  id          String   @id @default(uuid())
  poNumber    String   @unique @map("po_number")
  supplierId  String   @map("supplier_id")
  supplierName String  @map("supplier_name")
  orderDate   DateTime @map("order_date")
  expectedDate DateTime? @map("expected_date")
  status      String   @default("draft")
  subtotal    Decimal  @db.Decimal(15, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(15, 2) @map("tax_amount")
  total       Decimal  @db.Decimal(15, 2)
  currency    String   @default("USD")
  exchangeRate Decimal @default(1) @db.Decimal(15, 6) @map("exchange_rate")
  notes       String?
  requisitionId String? @map("requisition_id")
  requisition   ErpPurchaseRequisition? @relation(fields: [requisitionId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  lines    ErpPurchaseOrderLine[]
  receipts ErpGoodsReceipt[]

  @@map("erp_purchase_orders")
}

model ErpPurchaseOrderLine {
  id        String  @id @default(uuid())
  poId      String  @map("po_id")
  productId String  @map("product_id")
  productName String @map("product_name")
  quantity  Decimal @db.Decimal(15, 2)
  receivedQty Decimal @default(0) @db.Decimal(15, 2) @map("received_qty")
  unitPrice Decimal @db.Decimal(15, 2) @map("unit_price")
  total     Decimal @db.Decimal(15, 2)

  po ErpPurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@map("erp_purchase_order_lines")
}

model ErpGoodsReceipt {
  id          String   @id @default(uuid())
  receiptNo   String   @unique @map("receipt_no")
  poId        String   @map("po_id")
  po          ErpPurchaseOrder @relation(fields: [poId], references: [id])
  receivedAt  DateTime @default(now()) @map("received_at")
  status      String   @default("pending")
  notes       String?
  inspectedBy String?  @map("inspected_by")
  inspectionStatus String? @map("inspection_status")
  createdAt   DateTime @default(now()) @map("created_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  lines ErpGoodsReceiptLine[]

  @@map("erp_goods_receipts")
}

model ErpGoodsReceiptLine {
  id          String  @id @default(uuid())
  receiptId   String  @map("receipt_id")
  receipt     ErpGoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  productName String  @map("product_name")
  poLineId    String  @map("po_line_id")
  quantity    Decimal @db.Decimal(15, 2)
  batchNo     String? @map("batch_no")
  serialNo    String? @map("serial_no")
  location    String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("erp_goods_receipt_lines")
}

model ErpPurchaseRequisition {
  id             String   @id @default(uuid())
  requisitionNo  String   @unique @map("requisition_no")
  requestedBy    String   @map("requested_by")
  department     String
  requiredDate   DateTime @map("required_date")
  status         String   @default("draft")
  notes          String?
  approvedBy     String?  @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  items ErpPurchaseRequisitionItem[]
  pos   ErpPurchaseOrder[]

  @@map("erp_purchase_requisitions")
}

model ErpPurchaseRequisitionItem {
  id           String  @id @default(uuid())
  requisitionId String @map("requisition_id")
  requisition  ErpPurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  productId    String  @map("product_id")
  productName  String  @map("product_name")
  quantity     Decimal @db.Decimal(15, 2)
  estimatedCost Decimal @db.Decimal(15, 2) @map("estimated_cost")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("erp_purchase_requisition_items")
}

// ============ CRM ============

model ErpCustomer {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        String   @default("company")
  segment     String?  @default("retail")
  contactPerson String? @map("contact_person")
  email       String?
  phone       String?
  mobile      String?
  address     String?
  city        String?
  country     String?
  taxId       String?  @map("tax_id")
  vatNumber   String?  @map("vat_number")
  tinNumber   String?  @map("tin_number")
  creditLimit Decimal  @default(0) @db.Decimal(15, 2) @map("credit_limit")
  balance     Decimal  @default(0) @db.Decimal(15, 2)
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  leads ErpLead[]

  @@map("erp_customers")
}

model ErpLead {
  id          String   @id @default(uuid())
  customerId  String?  @map("customer_id")
  customer    ErpCustomer? @relation(fields: [customerId], references: [id])
  companyName String   @map("company_name")
  contactName String   @map("contact_name")
  email       String?
  phone       String?
  source      String?
  stage       String   @default("new")
  value       Decimal  @default(0) @db.Decimal(15, 2)
  probability Int      @default(0)
  assignedTo  String?  @map("assigned_to")
  notes       String?
  expectedCloseDate DateTime? @map("expected_close_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interactions ErpLeadInteraction[]

  @@map("erp_leads")
}

model ErpLeadInteraction {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      ErpLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  subject   String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("erp_lead_interactions")
}

// ============ SUPPLIER MANAGEMENT ============

model ErpSupplier {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  contactPerson   String?  @map("contact_person")
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String?
  taxId           String?  @map("tax_id")
  vatNumber       String?  @map("vat_number")
  tinNumber       String?  @map("tin_number")
  itf263Status    String   @default("unknown") @map("itf263_status")
  itf263Expiry    DateTime? @map("itf263_expiry")
  itf263DocUrl    String?  @map("itf263_doc_url")
  paymentTerms    String?  @map("payment_terms")
  balance         Decimal  @default(0) @db.Decimal(15, 2)
  performanceScore Int?    @map("performance_score")
  category        String?  @default("general")
  blacklisted     Boolean  @default(false)
  notes           String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

  contracts ErpSupplierContract[]

  @@map("erp_suppliers")
}

model ErpSupplierContract {
  id          String   @id @default(uuid())
  supplierId  String   @map("supplier_id")
  supplier    ErpSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  contractNo  String   @unique @map("contract_no")
  title       String
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  value       Decimal  @db.Decimal(15, 2)
  currency    String   @default("USD")
  status      String   @default("active")
  terms       String?
  docUrl      String?  @map("doc_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("erp_supplier_contracts")
}

// ============ WAREHOUSE MANAGEMENT ============

model ErpWarehouse {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  location    String?
  type        String   @default("standard")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  zones  ErpWarehouseZone[]
  stocks ErpWarehouseStock[]
  counts ErpCycleCount[]

  @@map("erp_warehouses")
}

model ErpWarehouseZone {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  warehouse   ErpWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String
  name        String
  type        String   @default("storage")
  capacity    Decimal? @db.Decimal(15, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("erp_warehouse_zones")
}

model ErpWarehouseStock {
  id          String  @id @default(uuid())
  warehouseId String  @map("warehouse_id")
  warehouse   ErpWarehouse @relation(fields: [warehouseId], references: [id])
  productId   String  @map("product_id")
  product     ErpProduct @relation(fields: [productId], references: [id])
  quantity    Decimal @default(0) @db.Decimal(15, 2)
  location    String?
  batchNo     String? @map("batch_no")
  serialNo    String? @map("serial_no")

  @@unique([warehouseId, productId, batchNo])
  @@map("erp_warehouse_stocks")
}

model ErpStockMovement {
  id          String   @id @default(uuid())
  movementNo  String   @unique @map("movement_no")
  type        String
  productId   String   @map("product_id")
  productName String   @map("product_name")
  quantity    Decimal  @db.Decimal(15, 2)
  fromWarehouseId String? @map("from_warehouse_id")
  toWarehouseId   String? @map("to_warehouse_id")
  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")
  notes       String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  branchId    String?  @map("branch_id")
  branch      ErpBranch? @relation(fields: [branchId], references: [id])

