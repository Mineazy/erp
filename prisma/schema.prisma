  @@map("erp_employees")
}

model ErpPayrollEntry {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  employee        ErpEmployee @relation(fields: [employeeId], references: [id])
  period          String
  basicPay        Decimal  @db.Decimal(15, 2) @map("basic_pay")
  overtime        Decimal  @default(0) @db.Decimal(15, 2)
  allowances      Decimal  @default(0) @db.Decimal(15, 2)
  grossPay        Decimal  @db.Decimal(15, 2) @map("gross_pay")
  payeTax         Decimal  @default(0) @db.Decimal(15, 2) @map("paye_tax")
  aidsLevy        Decimal  @default(0) @db.Decimal(15, 2) @map("aids_levy")
  nssaDeduction   Decimal  @default(0) @db.Decimal(15, 2) @map("nssa_deduction")
  necDeduction    Decimal  @default(0) @db.Decimal(15, 2) @map("nec_deduction")
  zimdefDeduction Decimal  @default(0) @db.Decimal(15, 2) @map("zimdef_deduction")
  otherDeductions Decimal  @default(0) @db.Decimal(15, 2) @map("other_deductions")
  netPay          Decimal  @db.Decimal(15, 2) @map("net_pay")
  currency        String   @default("USD")
  status          String   @default("draft")
  paidAt          DateTime? @map("paid_at")
  postedToZimra   Boolean  @default(false) @map("posted_to_zimra")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("erp_payroll_entries")
}

model ErpAttendance {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
