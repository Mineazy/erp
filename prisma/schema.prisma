  checkOut   DateTime? @map("check_out")
  status     String   @default("present")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("erp_attendance")
}

model ErpLeaveRequest {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  employee    ErpEmployee @relation(fields: [employeeId], references: [id])
  leaveType   String   @map("leave_type")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  days        Int
  reason      String?
  status      String   @default("pending")
  approvedBy  String?  @map("approved_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("erp_leave_requests")
}

// ============ FLEET MANAGEMENT ============

model ErpVehicle {
  id            String   @id @default(uuid())
  plateNumber   String   @unique @map("plate_number")
  model         String
  make          String
  year          Int?
  vin           String?  @map("vin")
  type          String   @default("light_vehicle")
  fuelType      String?  @map("fuel_type")
  capacity      Decimal? @db.Decimal(15, 2)
  insurancePolicy String? @map("insurance_policy")
  insuranceExpiry DateTime? @map("insurance_expiry")
  licenceExpiry DateTime? @map("licence_expiry")
  status        String   @default("active")
  assignedDriver String? @map("assigned_driver")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  refuels    ErpFuelRecord[]
  services   ErpServiceRecord[]
  dispatches ErpVehicleDispatch[]

  @@map("erp_vehicles")
}

model ErpFuelRecord {
  id          String   @id @default(uuid())
  vehicleId   String   @map("vehicle_id")
  vehicle     ErpVehicle @relation(fields: [vehicleId], references: [id])
  refuelDate  DateTime @map("refuel_date")
  quantity    Decimal  @db.Decimal(15, 2)
  unitCost    Decimal  @db.Decimal(15, 2) @map("unit_cost")
  totalCost   Decimal  @db.Decimal(15, 2) @map("total_cost")
  odometer    Int?
  fuelType    String?  @map("fuel_type")
  vendor      String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("erp_fuel_records")
}

model ErpServiceRecord {
  id            String   @id @default(uuid())
  vehicleId     String   @map("vehicle_id")
  vehicle       ErpVehicle @relation(fields: [vehicleId], references: [id])
  serviceDate   DateTime @map("service_date")
  serviceType   String   @map("service_type")
  description   String?
  odometer      Int?
  cost          Decimal  @db.Decimal(15, 2)
  vendor        String?
  nextServiceDate DateTime? @map("next_service_date")
  nextServiceOdometer Int? @map("next_service_odometer")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("erp_service_records")
}

model ErpVehicleDispatch {
  id              String   @id @default(uuid())
  vehicleId       String   @map("vehicle_id")
  vehicle         ErpVehicle @relation(fields: [vehicleId], references: [id])
  dispatchedAt    DateTime @default(now()) @map("dispatched_at")
  returnedAt      DateTime? @map("returned_at")
  driverName      String   @map("driver_name")
  driverContact   String?  @map("driver_contact")
  origin          String
  destination     String
  purpose         String?
  startOdometer   Int?     @map("start_odometer")
  endOdometer     Int?     @map("end_odometer")
  distanceKm      Decimal? @db.Decimal(10, 2) @map("distance_km")
  status          String   @default("in_transit")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("erp_vehicle_dispatches")
}

// ============ ENGINEERING WORKSHOP ============

model ErpEquipment {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  type         String
  model        String?
  manufacturer String?
  serialNo     String?  @map("serial_no")
  location     String?
  purchaseDate DateTime? @map("purchase_date")
  purchaseCost Decimal?  @db.Decimal(15, 2) @map("purchase_cost")
  status       String   @default("operational")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workOrders ErpWorkOrder[]

  @@map("erp_equipment")
}

model ErpWorkOrder {
  id           String   @id @default(uuid())
  woNumber     String   @unique @map("wo_number")
  equipmentId  String   @map("equipment_id")
  equipment    ErpEquipment @relation(fields: [equipmentId], references: [id])
  type         String
  priority     String   @default("medium")
  description  String
  assignedTo   String?  @map("assigned_to")
  scheduledDate DateTime? @map("scheduled_date")
  completedAt  DateTime? @map("completed_at")
  labourHours  Decimal? @db.Decimal(10, 2) @map("labour_hours")
  labourCost   Decimal? @db.Decimal(15, 2) @map("labour_cost")
  partsCost    Decimal? @db.Decimal(15, 2) @map("parts_cost")
  totalCost    Decimal? @db.Decimal(15, 2) @map("total_cost")
  status       String   @default("open")
  failureMode  String?  @map("failure_mode")
  downtimeHours Decimal? @db.Decimal(10, 2) @map("downtime_hours")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parts ErpWorkOrderPart[]

  @@map("erp_work_orders")
}

model ErpWorkOrderPart {
  id          String  @id @default(uuid())
  woId        String  @map("wo_id")
  wo          ErpWorkOrder @relation(fields: [woId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id")
  productName String  @map("product_name")
  quantity    Decimal @db.Decimal(15, 2)
  unitCost    Decimal @db.Decimal(15, 2) @map("unit_cost")
  totalCost   Decimal @db.Decimal(15, 2) @map("total_cost")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("erp_work_order_parts")
}

